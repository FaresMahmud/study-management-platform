# Copie este arquivo para .env e preencha com seus dados locais
# O arquivo .env nunca deve ser commitado no Git

# Servidor
SERVER_PORT=8080

# Banco de dados MySQL
# Crie o banco antes: CREATE DATABASE studyplatform;
DB_URL=jdbc:mysql://localhost:3306/studyplatform?useSSL=false&serverTimezone=America/Sao_Paulo&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=sua_senha_aqui

# JWT
# Use qualquer string longa e aleatória como secret
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria
JWT_EXPIRATION=86400000
